POSTGRES_USER=bookscan
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bookscan

# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret

APP_USERNAME=admin

# Generate with: cd api && .venv/bin/python generate_hash.py yourpassword
PASSWORD_HASH=$2b$12$...

# Optional: Gemini API key for AI book summary generation.
# Free tier limits: 10 RPM / 500 RPD. Get a key at https://aistudio.google.com/app/apikey
# Leave unset to disable AI summaries entirely.
GEMINI_API_KEY=

# eBay export settings — these values must exactly match the names
# configured in your eBay account under Seller Hub → Account →
# Shipping preferences and Return preferences. Case-sensitive.
EBAY_SHIPPING_PROFILE=Media Mail Books
EBAY_SHIPPING_PROFILE_ALT=Standard Mail Books
EBAY_RETURN_POLICY=No Returns
# Public URL for this instance — used in signed photo URLs for eBay export.
# For local dev/testing, set to https://bloke.local:3001 (or your machine's IP).
# After changing, recreate the container: docker compose ... up -d api
# (restart alone won't pick up .env changes)
SITE_URL=https://bookscan.luhrs.net

EBAY_PAYMENT_PROFILE=

# Seller zip code for eBay listings — used in Item Location field
EBAY_SHIPPING_LOCATION=

# Photo signing secret — used to generate time-limited signed URLs for eBay image crawling
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
PHOTO_SIGNING_SECRET=
